---
const analyses = [
  {
    href: '/analyses/alternative-data-moat-decay',
    title: 'Alternative-data moats are decaying assets',
    subtitle: 'Visualizing competitive-moat decay across four Actions Capital portfolio companies',
    date: 'May 2026',
  },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Analyses — Aditya Bhosale</title>
    <link
      href="https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400;0,500;0,600;1,400&display=swap"
      rel="stylesheet"
    />
    <style>
      body {
        margin: 0;
        font-family: 'EB Garamond', Georgia, serif;
        color: #111827;
        background: #ffffff;
        font-size: 18px;
        line-height: 1.6;
        -webkit-font-smoothing: antialiased;
      }
      .page {
        max-width: 720px;
        margin: 0 auto;
        padding: 48px 24px 96px;
      }
      .breadcrumb {
        font-size: 14px;
        color: #6b7280;
        margin-bottom: 24px;
      }
      .breadcrumb a {
        color: #6b7280;
        text-decoration: none;
      }
      .breadcrumb a:hover {
        color: #111827;
        text-decoration: underline;
      }
      h1 {
        font-size: 32px;
        font-weight: 600;
        margin: 0 0 12px;
        letter-spacing: -0.01em;
      }
      .intro {
        color: #4b5563;
        margin: 0 0 40px;
      }
      .analysis-item {
        padding: 20px 0;
        border-top: 1px solid #e5e7eb;
      }
      .analysis-item:last-child {
        border-bottom: 1px solid #e5e7eb;
      }
      .analysis-item a {
        color: #111827;
        text-decoration: none;
        display: block;
      }
      .analysis-item a:hover h2 {
        color: #1d4ed8;
      }
      .analysis-item h2 {
        font-size: 22px;
        font-weight: 600;
        margin: 0 0 6px;
        transition: color 150ms;
      }
      .analysis-item .subtitle {
        color: #4b5563;
        font-style: italic;
        margin: 0 0 6px;
        font-size: 16px;
      }
      .analysis-item .date {
        color: #6b7280;
        font-size: 14px;
      }
    </style>
  </head>
  <body>
    <div class="page">
      <div class="breadcrumb">
        <a href="/">aditya bhosale</a> / analyses
      </div>

      <h1>Analyses</h1>
      <p class="intro">
        Long-form analytical work, occasionally interactive. Pushback welcome at
        <a href="mailto:adityanb@sas.upenn.edu" style="color: #1d4ed8;">adityanb@sas.upenn.edu</a>.
      </p>

      {analyses.map((a) => (
        <div class="analysis-item">
          <a href={a.href}>
            <h2>{a.title}</h2>
            <p class="subtitle">{a.subtitle}</p>
            <div class="date">{a.date}</div>
          </a>
        </div>
      ))}
    </div>
  </body>
</html>
