---
import { getCollection, render } from "astro:content";

const allPosts = await getCollection("thoughts");

// Sort all posts by date desc to find the single newest
const sortedByDate = [...allPosts].sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);
const newestId = sortedByDate[0]?.id;

// Group by topic
const byTopic: Record<string, typeof allPosts> = {};
for (const post of allPosts) {
  const t = post.data.topic;
  if (!byTopic[t]) byTopic[t] = [];
  byTopic[t].push(post);
}

// Sort posts within each topic by date, newest first
for (const topic of Object.keys(byTopic)) {
  byTopic[topic].sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
}

const topics = Object.keys(byTopic).sort();

// Render each post's Markdown body to HTML, and extract preview text
const postsWithContent = await Promise.all(
  allPosts.map(async (post) => {
    const { Content } = await render(post);

    // Extract first paragraph from raw markdown body for preview.
    // Skip blank lines, frontmatter is already stripped by Astro.
    const firstPara = post.body
      ?.split(/\n\s*\n/)
      .map((p) => p.trim())
      .find((p) => p.length > 0) ?? "";

    // Strip markdown syntax (links, bold, italic, code, headings) for clean preview
    const cleaned = firstPara
      .replace(/`([^`]+)`/g, "$1")           // inline code
      .replace(/\*\*([^*]+)\*\*/g, "$1")     // bold
      .replace(/\*([^*]+)\*/g, "$1")         // italic
      .replace(/\[([^\]]+)\]\([^)]+\)/g, "$1") // links
      .replace(/^#+\s*/, "")                 // headings
      .replace(/\s+/g, " ")                  // collapse whitespace
      .trim();

    const preview = cleaned.length > 120
      ? cleaned.slice(0, 120).replace(/\s+\S*$/, "") + "…"
      : cleaned;

    return { post, Content, preview };
  })
);

const contentMap = new Map(postsWithContent.map(({ post, Content, preview }) => [post.id, { Content, preview }]));
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="thoughts — Aditya Bhosale" />
  <title>working notes — Aditya Bhosale</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400;0,500;1,400&display=swap" rel="stylesheet" />
  <style>
    :root {
    --bg: #ffffff;
    --ink: #1a1a1a;
    --ink-muted: #555555;
    --link: #1a1a1a;
    --rule: #d8d8d8;
    --cta-bg: #1a1a1a;
    --cta-bg-hover: #000000;
    --cta-fg: #ffffff;
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    background: var(--bg);
    color: var(--ink);
    font-family: 'EB Garamond', Georgia, serif;
    font-size: 19px;
    line-height: 1.55;
    -webkit-font-smoothing: antialiased;
    padding: 60px 24px 80px;
  }

  main {
    max-width: 620px;
    margin: 0 auto;
  }

  h1 {
    font-size: 28px;
    font-weight: 500;
    margin-bottom: 6px;
    letter-spacing: -0.01em;
  }

  h1 a {
    color: var(--ink);
    text-decoration: none;
  }

  .socials {
    margin-bottom: 28px;
    color: var(--ink-muted);
    font-size: 16px;
  }

  .socials a {
    color: var(--ink-muted);
    text-decoration: none;
    margin-right: 14px;
  }

  .socials a:hover {
    color: var(--ink);
    text-decoration: underline;
  }

  p {
    margin-bottom: 18px;
  }

  a {
    color: var(--link);
  }

  a:hover {
    text-decoration: none;
  }

  .label {
    font-style: italic;
    color: var(--ink-muted);
    margin-top: 28px;
    margin-bottom: 8px;
    font-size: 17px;
  }

  /* CTA button — promoted current build link */
  .cta-wrap {
    margin: 36px 0 40px;
  }

  .cta {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: var(--cta-bg);
    color: var(--cta-fg);
    padding: 14px 22px;
    text-decoration: none;
    font-family: 'EB Garamond', Georgia, serif;
    font-size: 18px;
    font-weight: 500;
    letter-spacing: -0.005em;
    border-radius: 2px;
    transition: background 0.15s ease, transform 0.15s ease;
  }

  .cta:hover {
    background: var(--cta-bg-hover);
    transform: translateY(-1px);
  }

  .cta-arrow {
    font-size: 0.9em;
    line-height: 1;
  }

  .cta-sublabel {
    display: block;
    margin-top: 8px;
    font-style: italic;
    color: var(--ink-muted);
    font-size: 15px;
    line-height: 1.4;
  }

  hr {
    border: none;
    border-top: 1px solid var(--rule);
    margin: 36px 0 28px;
  }

  .footer-links {
    color: var(--ink-muted);
    font-size: 16px;
  }

  .footer-links a {
    color: var(--ink-muted);
    text-decoration: none;
    margin-right: 18px;
  }

  .footer-links a:hover {
    color: var(--ink);
    text-decoration: underline;
  }

  /* arrow superscript */
  .ext::after {
    content: " ↗︎";
    font-size: 0.85em;
  }

  @media (max-width: 600px) {
    body { padding: 40px 20px 60px; font-size: 18px; }
    h1 { font-size: 24px; }
    .cta { font-size: 17px; padding: 13px 20px; }
  }

    /* thoughts-page additions */
    h2.topic {
      font-size: 22px;
      font-weight: 500;
      margin-top: 48px;
      margin-bottom: 14px;
      letter-spacing: -0.005em;
    }

    details.entry {
      margin-bottom: 24px;
      border-bottom: 1px solid var(--rule);
      padding-bottom: 18px;
    }
    details.entry:last-child {
      border-bottom: none;
    }

    details.entry > summary {
      cursor: pointer;
      list-style: none;
      padding: 4px 0;
      transition: opacity 0.15s ease;
    }
    details.entry > summary::-webkit-details-marker {
      display: none;
    }
    details.entry > summary:hover {
      opacity: 0.7;
    }

    .entry-date {
      font-style: italic;
      color: var(--ink-muted);
      font-size: 16px;
      margin-bottom: 2px;
    }
    .entry-title {
      font-size: 19px;
      font-weight: 500;
      margin-bottom: 4px;
      display: block;
    }
    .entry-preview {
      color: var(--ink-muted);
      font-size: 17px;
      line-height: 1.5;
    }

    details.entry[open] > summary .entry-preview {
      display: none;
    }
    details.entry[open] > summary {
      margin-bottom: 12px;
    }

    .entry-body {
      padding-top: 4px;
    }
    .entry-body p {
      margin-bottom: 14px;
    }
    .entry-body :last-child {
      margin-bottom: 0;
    }

    .back-link {
      display: inline-block;
      margin-bottom: 24px;
      color: var(--ink-muted);
      font-size: 16px;
    }
    .empty-state {
      color: var(--ink-muted);
      font-style: italic;
    }
  </style>
</head>
<body>
  <main>
    <a href="/" class="back-link">← back</a>
    <h1>working notes</h1>

    {topics.length === 0 && (
      <p class="empty-state">nothing here yet.</p>
    )}

    {topics.map((topic) => (
      <section>
        <h2 class="topic">{topic}</h2>
        {byTopic[topic].map((post) => {
          const entry = contentMap.get(post.id)!;
          const isNewest = post.id === newestId;
          return (
            <details class="entry" open={isNewest}>
              <summary>
                <div class="entry-date">
                  {post.data.date.toLocaleDateString("en-US", { year: "numeric", month: "long" })}
                </div>
                <span class="entry-title">{post.data.title}</span>
                <span class="entry-preview">{entry.preview}</span>
              </summary>
              <div class="entry-body">
                <entry.Content />
              </div>
            </details>
          );
        })}
      </section>
    ))}
  </main>
</body>
</html>